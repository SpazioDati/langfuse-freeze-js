{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022", "dom"],
        "types": ["node"],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "dist",
        "rootDir": "src",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "isolatedModules": true
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist", "vitest.config.ts", "vitest.unit.config.ts"]
}
